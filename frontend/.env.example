# API Configuration
#
# Emulador Android (en la misma PC con Docker):
#   API_BASE_URL=http://localhost:3000/api
#   (la app convierte localhost → 10.0.2.2 automáticamente)
#
# Celular físico (misma red WiFi que tu PC):
#   1. En PowerShell: ipconfig  →  busca tu IPv4 de WiFi (ej. 192.168.18.27)
#   2. Usa esa IP (NO uses localhost ni 10.0.2.2):
API_BASE_URL=http://192.168.18.27:3000/api

# App Configuration
APP_NAME=CacaoLens
APP_VERSION=1.0.0

# Frontend Port (solo para web)
FRONTEND_PORT=80
