# Node Environment
NODE_ENV=production
PORT=3000

# Database Configuration (PostgreSQL)
# Local (Docker Compose):
# DATABASE_URL="postgresql://root:rootpassword123@postgres:5432/cacaolens?schema=public"
# Render: usa la Internal Database URL de tu PostgreSQL en Render (no "postgres" como host)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DB_HOST=postgres
DB_PORT=5432
DB_USER=root
DB_PASSWORD=rootpassword123
DB_NAME=cacaolens

# ML Service Configuration
ML_SERVICE_URL=http://ml-service:8000

# JWT Secret (generate a secure random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:80,http://localhost:3000

# Backend Port
BACKEND_PORT=3000